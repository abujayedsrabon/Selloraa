rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: vendors
    // Document ID: vendorId (uid)
    // Fields: uid, storeName, slug, logo, location, packageId, createdAt
    //
    // Collection: products
    // Document ID: productId
    // Fields: id, vendorId, name, description, price, stock, imageUrl, createdAt
    //
    // Collection: orders
    // Document ID: orderId
    // Fields: id, vendorId, customerName, customerEmail, items, total, status, fakeProbability, createdAt
    //
    // Collection: slugs
    // Document ID: slug
    // Fields: vendorId
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.vendorId;
    }
    function isNewDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.vendorId;
    }

    // Domain Validators
    function isValidVendor(data) {
      return data.keys().hasAll(['uid', 'storeName', 'slug', 'createdAt']) &&
             data.uid is string && data.storeName is string && data.slug is string &&
             data.storeName.size() > 0 && data.storeName.size() < 100 &&
             data.slug.size() > 0 && data.slug.size() < 50;
    }
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'vendorId', 'name', 'price', 'stock', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is int && data.stock >= 0;
    }
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'vendorId', 'customerName', 'customerEmail', 'items', 'total', 'status', 'createdAt']) &&
             data.customerName is string && data.customerName.size() > 0 &&
             data.customerEmail is string && data.customerEmail.size() > 0 &&
             data.status in ['pending', 'confirmed', 'shipped', 'delivered'];
    }

    // Rules
    match /vendors/{vendorId} {
      allow read: if true; // Publicly readable for storefront
      allow create, update: if isOwner(vendorId) && isValidVendor(request.resource.data);
      allow delete: if isOwner(vendorId);
    }

    match /products/{productId} {
      allow read: if true; // Publicly readable for storefront
      allow create: if isNewDocOwner() && isValidProduct(request.resource.data);
      allow update: if isDocOwner() && isValidProduct(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /orders/{orderId} {
      allow read: if isDocOwner(); // Only vendor can read their orders
      allow create: if isValidOrder(request.resource.data); // Customers can create orders
      allow update: if isDocOwner() && isValidOrder(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /slugs/{slug} {
      allow read: if true; // Publicly readable for slug lookup
      allow create: if isAuthenticated() && request.resource.data.vendorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.vendorId == request.auth.uid;
    }
  }
}
